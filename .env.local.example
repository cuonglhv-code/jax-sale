# Copy to .env.local and fill from `supabase start` output.
# PUBLIC (safe for browser) — must carry the NEXT_PUBLIC_ prefix.
NEXT_PUBLIC_SUPABASE_URL="http://127.0.0.1:54421"
NEXT_PUBLIC_SUPABASE_ANON_KEY="<anon key from `supabase start`>"

# SERVER-ONLY — NEVER prefix with NEXT_PUBLIC_ and never expose to the browser.
# Used only by admin actions (create-login, force-signout) and seeding.
SUPABASE_SERVICE_ROLE_KEY="<service_role key from `supabase start`>"
